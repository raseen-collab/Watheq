// وثيق — مخطّط قاعدة البيانات (Prisma + PostgreSQL)
// يدعم الوضع المزدوج: مدير جمعية ملاك / مدير أملاك.
// متوافق مع Vercel (Postgres/Neon/Supabase) و Netlify.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================== المستخدم والوضع المزدوج =====================
enum Mode {
  ASSOCIATION_MANAGER // مدير جمعية ملاك
  PROPERTY_MANAGER    // مدير أملاك / صاحب عقارات متعددة
}

model User {
  id           String        @id @default(cuid())
  name         String
  phone        String        @unique          // للتواصل وتسجيل الدخول
  email        String?       @unique
  activeMode   Mode          @default(PROPERTY_MANAGER) // الوضع الحالي المعروض
  enabledModes Mode[]        @default([PROPERTY_MANAGER]) // الأوضاع المُفعّلة للحساب
  associations Association[]
  properties   Property[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

// ===================== وضع جمعيات الملاك (قائم) =====================
model Association {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  name        String
  units       Int      @default(0)
  monthlyFee  Decimal  @default(0) @db.Decimal(10, 2)
  certExpiry  DateTime?
  fundBalance Decimal  @default(0) @db.Decimal(12, 2)
  owners      Owner[]
  createdAt   DateTime @default(now())

  @@index([userId])
}

model Owner {
  id            String      @id @default(cuid())
  association   Association @relation(fields: [associationId], references: [id], onDelete: Cascade)
  associationId String
  name          String
  unit          String?
  phone         String?
  monthsLate    Int         @default(0)
  lastPaid      DateTime?

  @@index([associationId])
}

// ===================== وضع مديري الأملاك (الجديد) =====================
model Property {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  name      String   // اسم أو عنوان العقار (مثال: برج الياسمين)
  address   String?
  city      String?
  tenants   Tenant[]
  createdAt DateTime @default(now())

  @@index([userId])
}

enum RentCycle {
  MONTHLY    // شهري
  QUARTERLY  // ربع سنوي
  SEMIANNUAL // نصف سنوي
  ANNUAL     // سنوي
}

enum PaymentStatus {
  PAID    // مسدّد
  PENDING // مستحق (لم يحن/لم يتأخر)
  LATE    // متأخر
}

model Tenant {
  id            String        @id @default(cuid())
  property      Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId    String

  // بيانات المستأجر المطلوبة
  name          String        // اسم المستأجر
  unit          String        // رقم الوحدة
  phone         String?
  nationalId    String?       // رقم الهوية/الإقامة (لازم للإنذار النظامي والتنفيذ)
  rentAmount    Decimal       @db.Decimal(10, 2) // قيمة الإيجار للدورة
  rentCycle     RentCycle     @default(MONTHLY)
  dueDay        Int           @default(1)  // يوم الاستحقاق من كل دورة (1-28)

  // العقد الموحّد
  contractNo    String?       // رقم عقد الإيجار الموحّد في شبكة إيجار
  contractStart DateTime      // تاريخ بدء العقد
  contractEnd   DateTime      // تاريخ انتهاء العقد

  status        PaymentStatus @default(PENDING) // الحالة الحالية المختصرة
  payments      Payment[]
  notices       Notice[]
  createdAt     DateTime      @default(now())

  @@index([propertyId])
}

model Payment {
  id        String        @id @default(cuid())
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId  String
  amount    Decimal       @db.Decimal(10, 2)
  dueDate   DateTime      // تاريخ الاستحقاق لهذه الدورة
  paidDate  DateTime?     // تاريخ السداد الفعلي (إن سُدّد)
  status    PaymentStatus @default(PENDING)
  createdAt DateTime      @default(now())

  @@index([tenantId, status])
  @@index([dueDate])
}

// مستوى الإشعار المتدرّج
enum NoticeLevel {
  REMINDER // تذكير ودّي (قبل الاستحقاق بـ5 أيام)
  LATE     // تنبيه تأخير (بعد يومين من الاستحقاق)
  FINAL    // إنذار نهائي (بعد 15 يومًا)
}

// سجل ما أُرسل — يمنع التكرار ويوثّق للتنفيذ
model Notice {
  id        String      @id @default(cuid())
  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId  String
  paymentId String?     // الدفعة المرتبطة بالإنذار
  level     NoticeLevel
  channel   String      @default("whatsapp") // whatsapp | sms | pdf
  body      String      @db.Text             // نص الإشعار المُرسَل (للأرشفة/التنفيذ)
  sentAt    DateTime    @default(now())

  @@index([tenantId, level])
  @@index([paymentId])
}
